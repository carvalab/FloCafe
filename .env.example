# FloCafe Environment Configuration
# Copy this file to .env and customize as needed.

# JWT secret for authentication tokens.
# If not set, FloCafe generates a random secret on first launch.
# JWT_SECRET=your-secure-random-string-here

# API server port (default: 3001)
# PORT=3001

# KDS server port (default: 3002)
# KDS_PORT=3002

# Node environment: development, production, test (default: development)
# NODE_ENV=development

# Google Drive integration for automated DB backups (#129).
# Both must be set for the "Google Drive" section under Settings >
# Integrations to be usable — if either is missing, the UI shows
# "Google Drive integration is not configured for this build" instead of a
# broken Connect button. See docs/google-drive-setup.md for how to create
# these in Google Cloud Console (APIs & Services > Credentials).
# GOOGLE_DRIVE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_DRIVE_CLIENT_SECRET=your-client-secret
