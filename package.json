{
  "name": "flo-desktop",
  "version": "1.9.2",
  "description": "Flo - Self-hosted Point of Sale System",
  "engines": {
    "node": ">=22.0.0"
  },
  "main": "dist/index.js",
  "scripts": {
    "clean": "node kill-ports.js 3001 3002",
    "predev": "",
    "dev": "npm run clean && npm run build:frontend && npm run build && electron .",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "tsc",
    "lint:backend": "eslint main/",
    "lint": "npm run lint:backend && cd frontend && npm run lint",
    "build:frontend": "cd frontend && npm ci && npx cross-env NEXT_BUILD_MODE=desktop NEXT_PUBLIC_API_URL=http://localhost:3001/api npm run build",
    "build:all-platforms": "npm run build:frontend && npm run build && electron-builder --win --mac --linux",
    "postinstall": "electron-builder install-app-deps",
    "build:win": "npm run build:frontend && npm run build && electron-builder --win",
    "build:appx": "npm run build:frontend && npm run build && electron-builder --win appx",
    "build:mac": "npm run build:frontend && npm run build && electron-builder --mac",
    "build:mas": "MAS_BUILD=1 npm run build:frontend && MAS_BUILD=1 npm run build && MAS_BUILD=1 electron-builder --mac mas --universal",
    "build:mas-dev": "MAS_BUILD=1 npm run build:frontend && MAS_BUILD=1 npm run build && MAS_BUILD=1 electron-builder --mac masDev",
    "build:linux": "npm run build:frontend && npm run build && electron-builder --linux",
    "release:linux": "npm run build:frontend && npm run build && electron-builder --linux --publish always",
    "release:mac": "npm run build:frontend && npm run build && electron-builder --mac --publish always",
    "release:win": "npm run build:frontend && npm run build && electron-builder --win --publish always",
    "pack": "electron-builder --dir",
    "start": "electron .",
    "rebuild": "HOME=~/.electron-gyp node-gyp rebuild --target=$(node -p \"require('./node_modules/electron/package.json').version\") --arch=$(node -p \"process.arch\") --dist-url=https://electronjs.org/headers --runtime=electron --directory node_modules/better-sqlite3",
    "test": "bash tests/run-test.sh npm run test:cors && bash tests/run-test.sh npm run test:first-run && bash tests/run-test.sh npm run test:security && bash tests/run-test.sh npm run test:backup && bash tests/run-test.sh npm run test:printer && bash tests/run-test.sh npm run test:translations && bash tests/run-test.sh npm run test:notes-validation && bash tests/run-test.sh npm run test:receipt-printing && bash tests/run-test.sh npm run test:cancel-override && bash tests/run-test.sh npm run test:sequence && bash tests/run-test.sh npm run test:integration-happy && bash tests/run-test.sh npm run test:integration-tax && bash tests/run-test.sh npm run test:integration-payments && bash tests/run-test.sh npm run test:integration-lifecycle && bash tests/run-test.sh npm run test:integration-reconciliation && bash tests/run-test.sh npm run test:integration-loyalty && bash tests/run-test.sh npm run test:integration-discount && bash tests/run-test.sh npm run test:loyalty-toggle && bash tests/run-test.sh npm run test:discount-system && bash tests/run-test.sh npm run test:integration-discount-settings && bash tests/run-test.sh npm run test:integration-loyalty-global && bash tests/run-test.sh npm run test:integration-loyalty-redemption && bash tests/run-test.sh npm run test:bills-print-api && bash tests/run-test.sh npm run test:issue-24 && bash tests/run-test.sh npm run test:tables-string-ids && bash tests/run-test.sh npm run test:held-orders && bash tests/run-test.sh npm run test:schema-health && bash tests/run-test.sh npm run test:master-pin && bash tests/run-test.sh npm run test:database-tools-api",
    "test:cors": "ts-node --transpile-only -P tests/tsconfig.json tests/cors-security.test.ts",
    "test:notes-validation": "ts-node --transpile-only -P tests/tsconfig.json tests/order-notes-validation.test.ts",
    "test:first-run": "node tests/run-electron-node-test.cjs tests/first-run-setup.test.ts",
    "test:security": "node tests/run-electron-node-test.cjs tests/security-hardening.test.ts",
    "test:backup": "ts-node --transpile-only -P tests/tsconfig.json tests/backup-restore.test.ts",
    "test:printer": "ts-node --transpile-only -P tests/tsconfig.json tests/printer.test.ts",
    "audit:db": "ts-node --transpile-only -P tests/tsconfig.json tests/db-audit.test.ts",
    "test:receipt-printing": "ts-node --transpile-only -P tests/tsconfig.json tests/receipt-printing.test.ts",
    "test:bills-print-api": "ts-node --transpile-only -P tests/tsconfig.json tests/bills-print-api.test.ts",
    "test:cancel-override": "node tests/run-electron-node-test.cjs tests/cancel-override.test.ts",
    "test:integration-happy": "node tests/run-electron-node-test.cjs tests/integration-happy-path.test.ts",
    "test:integration-tax": "node tests/run-electron-node-test.cjs tests/integration-tax.test.ts",
    "test:integration-payments": "node tests/run-electron-node-test.cjs tests/integration-payments.test.ts",
    "test:integration-lifecycle": "node tests/run-electron-node-test.cjs tests/integration-order-lifecycle.test.ts",
    "test:integration-reconciliation": "node tests/run-electron-node-test.cjs tests/integration-bill-reconciliation.test.ts",
    "test:integration-loyalty": "node tests/run-electron-node-test.cjs tests/integration-loyalty.test.ts",
    "test:integration-discount": "node tests/run-electron-node-test.cjs tests/integration-discount-edge.test.ts",
    "test:sequence": "node tests/run-electron-node-test.cjs tests/sequence-generation.test.ts",
    "test:loyalty-toggle": "node tests/run-electron-node-test.cjs tests/loyalty-toggle.test.ts",
    "test:discount-system": "node tests/run-electron-node-test.cjs tests/discount-system.test.ts",
    "test:integration-discount-settings": "node tests/run-electron-node-test.cjs tests/integration-discount-settings.test.ts",
    "test:integration-loyalty-global": "node tests/run-electron-node-test.cjs tests/integration-loyalty-global-rate.test.ts",
    "test:integration-loyalty-redemption": "node tests/run-electron-node-test.cjs tests/integration-loyalty-redemption.test.ts",
    "test:issue-24": "node tests/run-electron-node-test.cjs tests/issue-24-cancel-item-checkout.test.ts",
    "test:tables-string-ids": "node tests/run-electron-node-test.cjs tests/tables-string-ids.test.ts",
    "test:held-orders": "node tests/run-electron-node-test.cjs tests/held-orders.test.ts",
    "test:product-images": "node tests/run-electron-node-test.cjs tests/product-images.test.ts",
    "test:schema-health": "node tests/run-electron-node-test.cjs tests/schema-health.test.ts",
    "test:master-pin": "node tests/run-electron-node-test.cjs tests/master-pin.test.ts",
    "test:database-tools-api": "node tests/run-electron-node-test.cjs tests/database-tools-api.test.ts",
    "test:translations": "ts-node --transpile-only -P tests/tsconfig.json tests/translations.test.ts"
  },
  "author": {
    "name": "Flo",
    "email": "support@flo.local"
  },
  "homepage": "https://flo.local",
  "license": "MIT",
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/bcryptjs": "^3.0.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/bonjour": "^3.5.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.14.0",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.8",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "electron": "^31.7.7",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^11.10.0",
    "bonjour-service": "^1.2.1",
    "cors": "^2.8.5",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.9",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "node-thermal-printer": "^4.2.1",
    "qrcode": "^1.5.3",
    "uuid": "^9.0.1",
    "ws": "^8.17.0"
  },
  "build": {
    "appId": "com.flo.desktop",
    "productName": "Flo Cafe",
    "icon": "assets/icon-512.png",
    "afterPack": "scripts/afterPack.js",
    "asar": true,
    "asarUnpack": "**/node_modules/better-sqlite3/**/*",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "!**/better-sqlite3/build/Release/test_extension.node"
    ],
    "publish": {
      "provider": "github",
      "owner": "FreeOpenSourcePOS",
      "repo": "FloCafe",
      "releaseType": "release"
    },
    "extraResources": [
      {
        "from": "assets",
        "to": "assets"
      },
      {
        "from": "frontend/out",
        "to": "frontend-out"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "appx": {
      "applicationId": "FloCafe",
      "backgroundColor": "#1e1e2e",
      "publisherDisplayName": "Codify Apps Private Limited",
      "identityName": "CodifyAppsPrivateLimited.FloCafe",
      "publisher": "CN=34AFD24D-EC88-44B8-B309-08BB8A6BB5F7",
      "displayName": "Flo Cafe",
      "languages": [
        "en-US"
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.business",
      "identity": "Codify Apps Private Limited (BKDY677XJA)",
      "entitlements": "build/entitlements.plist",
      "entitlementsInherit": "build/entitlements.plist",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "notarize": false
    },
    "mas": {
      "category": "public.app-category.business",
      "identity": "Codify Apps Private Limited (BKDY677XJA)",
      "entitlements": "build/entitlements.mas.plist",
      "entitlementsInherit": "build/entitlements.mas.inherit.plist",
      "entitlementsLoginHelper": "build/entitlements.mas.loginhelper.plist",
      "provisioningProfile": "build/flo.provisionprofile",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "type": "distribution",
      "extendInfo": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "target": [
        {
          "target": "mas",
          "arch": "universal"
        }
      ]
    },
    "masDev": {
      "identity": "Apple Development: Codify Apps Private Limited (BKDY677XJA)"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "snap",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets",
      "category": "Office",
      "desktop": {
        "entry": {
          "Name": "Flo Cafe",
          "Comment": "Free, open-source POS for cafes and restaurants",
          "GenericName": "Point of Sale",
          "Keywords": "pos;point of sale;restaurant;cafe;billing;invoice;",
          "StartupWMClass": "flo-desktop"
        }
      }
    },
    "snap": {
      "confinement": "strict",
      "plugs": [
        "cups-control",
        "avahi-observe",
        "avahi-control",
        "raw-usb",
        "removable-media"
      ],
      "environment": {
        "TMPDIR": "$XDG_RUNTIME_DIR"
      }
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
